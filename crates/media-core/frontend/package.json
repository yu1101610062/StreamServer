{
  "name": "streamserver-console",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync:desktop-installers": "node ../../../scripts/sync-desktop-installers.mjs --allow-missing",
    "build": "npm run sync:desktop-installers && vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@tanstack/vue-query": "^5.68.0",
    "@vueuse/core": "^12.8.2",
    "element-plus": "^2.9.8",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "sass": "^1.86.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.6",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.2.8"
  }
}
